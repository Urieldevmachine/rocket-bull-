rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Leaderboard Entry Validation
    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['userId', 'username', 'score', 'updatedAt']) &&
             data.keys().size() == 4 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 20 &&
             data.score is int && data.score >= 0 &&
             data.updatedAt == request.time;
    }

    match /leaderboard/{entryId} {
      // Public view of high scores
      allow get: if true;
      allow list: if true; // Limited by client queries ideally, but rules wrap it

      allow create: if isSignedIn() && 
                      isValidId(entryId) && 
                      entryId == request.auth.uid && // Entry ID is the User ID for uniqueness
                      isValidLeaderboardEntry(incoming());

      allow update: if isSignedIn() &&
                      isOwner(existing().userId) &&
                      isValidLeaderboardEntry(incoming()) &&
                      incoming().userId == existing().userId &&
                      // Only update if the score is higher
                      incoming().score >= existing().score;

      allow delete: if false; // Scores are permanent or manual cleanup only
    }
  }
}
